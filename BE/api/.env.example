DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
# Most hosting platforms (e.g. Railway) inject PORT themselves — this default
# is only used when it's not set (local dev).
PORT=3000

# JWT signing secret for login sessions — use a long random value.
JWT_SECRET=

# WhatsApp Cloud API (Meta) — required for the region "Send WhatsApp Message"
# feature. Get these from the Meta for Developers dashboard for your WhatsApp
# Business app: https://developers.facebook.com/apps -> WhatsApp -> API Setup.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional — defaults shown:
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_DEFAULT_COUNTRY_CODE=961

# Stripe — payments. Get keys from https://dashboard.stripe.com/test/apikeys
# (test mode). Set up Connect (Express accounts) and the platform's
# subscription Product/Price in the Dashboard first — the subscription Price
# must be a per-unit recurring Price (see SUBSCRIPTION_PRICE_PER_CUSTOMER_USD
# below), since quantity = the admin's live customer count. Get a webhook
# signing secret via `stripe listen --print-secret` (dev) or Dashboard >
# Developers > Webhooks (prod).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_PRICE_ID=
# Base URL of the deployed frontend — builds Checkout/Portal/Connect redirect
# URLs, and is also the allowed CORS origin for the API (e.g. your Vercel domain).
FRONTEND_URL=http://localhost:5173

# Platform subscription price per customer/month (ADMIN -> SUPERADMIN billing).
# Used to compute both the Stripe subscription quantity/price and the amount
# quoted for the Whish Money manual-confirmation flow (no live API; see plan notes).
SUBSCRIPTION_PRICE_PER_CUSTOMER_USD=0.5
